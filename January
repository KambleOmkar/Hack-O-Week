4. FAQ Retrieval with TF-IDF

#include <stdio.h>
#include <string.h>

char *questions[] = {
    "admission process",
    "hostel facility",
    "college timing",
    "fees structure",
    "contact information"
};

char *answers[] = {
    "Admissions start in June.",
    "Hostel available for boys and girls.",
    "College timing is 9 AM to 5 PM.",
    "Fees are 90000 per year.",
    "Contact office at 0712-123456."
};

int score(char *query, char *faq) {

    int s = 0;

    char temp[200];
    strcpy(temp, query);

    char *token = strtok(temp," ");

    while(token) {

        if(strstr(faq,token))
            s++;

        token = strtok(NULL," ");
    }

    return s;
}

int main() {

    char input[200];

    printf("FAQ Retrieval Bot\n");

    printf("Ask Question: ");
    fgets(input,sizeof(input),stdin);

    input[strcspn(input,"\n")] = 0;

    int best=-1;
    int bestScore=0;

    for(int i=0;i<5;i++) {

        int s = score(input,questions[i]);

        if(s>bestScore) {

            bestScore=s;
            best=i;
        }
    }

    if(best!=-1)
        printf("Answer: %s\n",answers[best]);

    else
        printf("No relevant FAQ\n");

    return 0;
}


