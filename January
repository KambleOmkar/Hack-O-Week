1.Basic FAQ Responder

#include <stdio.h>
#include <string.h>

int main() {

    char query[200];

    printf("Institute FAQ Bot\n");
    printf("Type exit to quit\n");

    while(1) {

        printf("\nYou: ");
        fgets(query, sizeof(query), stdin);

        query[strcspn(query,"\n")] = 0;

        if(strlen(query)==0)
            continue;

        if(strcmp(query,"exit")==0) {
            printf("Bot: Goodbye\n");
            break;
        }

        if(strstr(query,"timing") || strstr(query,"time"))
            printf("Bot: College timing is 9 AM to 5 PM\n");

        else if(strstr(query,"fees"))
            printf("Bot: Annual fees are around 90000 INR\n");

        else if(strstr(query,"contact"))
            printf("Bot: Contact office at 0712-123456\n");

        else if(strstr(query,"hostel"))
            printf("Bot: Hostel facility available\n");

        else if(strstr(query,"admission"))
            printf("Bot: Admissions start in June\n");

        else
            printf("Bot: Sorry I don't know that\n");
    }

    return 0;
}


2.Preparing Student Queries

#include <stdio.h>
#include <string.h>
#include <ctype.h>

void preprocess(char *text) {

    for(int i=0;text[i];i++) {

        text[i]=tolower(text[i]);

        if(ispunct(text[i]))
            text[i]=' ';
    }
}

int main() {

    char query[200];

    printf("Query Preprocessing Bot\n");

    while(1) {

        printf("\nEnter Query: ");
        fgets(query,sizeof(query),stdin);

        query[strcspn(query,"\n")] = 0;

        if(strcmp(query,"exit")==0)
            break;

        preprocess(query);

        if(strstr(query,"fees"))
            printf("Bot: Fees are 90000 per year\n");

        else if(strstr(query,"timing"))
            printf("Bot: College timing is 9 AM to 5 PM\n");

        else if(strstr(query,"hostel"))
            printf("Bot: Hostel facility available\n");

        else
            printf("Bot: No matching FAQ\n");
    }

    return 0;
}


