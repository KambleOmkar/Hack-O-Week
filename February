6. Entity Extraction  For Dates And Courses

#include <stdio.h>
#include <string.h>
#include <ctype.h>

void toLowerCase(char *str)
{
    for(int i=0; str[i]; i++)
        str[i]=tolower(str[i]);
}

int extractSemester(char *str)
{
    for(int i=0; str[i]; i++)
    {
        if(str[i]=='s' && str[i+1]=='e' && str[i+2]=='m')
        {
            int j=i+3;
            while(str[j]==' ') j++;
            if(isdigit(str[j]))
                return str[j]-'0';
        }
    }
    return -1;
}

void extractCourse(char *str,char course[])
{
    char *courses[]={"cs","ai","it","ece","me","ce"};
    int n=6;

    for(int i=0;i<n;i++)
    {
        if(strstr(str,courses[i]))
        {
            strcpy(course,courses[i]);
            return;
        }
    }
    strcpy(course,"unknown");
}

void extractDateKeyword(char *str,char dateWord[])
{
    char *dates[]={"today","tomorrow","monday","tuesday","wednesday","thursday","friday","saturday"};
    int n=8;

    for(int i=0;i<n;i++)
    {
        if(strstr(str,dates[i]))
        {
            strcpy(dateWord,dates[i]);
            return;
        }
    }
    strcpy(dateWord,"scheduled");
}

void respond(int sem,char course[],char dateWord[])
{
    if(sem!=-1 && strcmp(course,"unknown")!=0)
    {
        printf("Exam schedule for SEM %d %s course is %s.\n",sem,course,dateWord);
    }
    else if(sem!=-1)
    {
        printf("Semester %d exams will be conducted next month as per university timetable.\n",sem);
    }
    else if(strcmp(course,"unknown")!=0)
    {
        printf("Course information for %s department is available on the institute portal.\n",course);
    }
    else
    {
        printf("Unable to extract semester or course information from the query.\n");
    }
}

int main()
{
    char input[200];
    char processed[200];
    char course[50];
    char dateWord[50];
    int sem;

    printf("Academic Query Entity Extraction System\n");
    printf("Type 'exit' to quit\n\n");

    while(1)
    {
        printf("You: ");
        fgets(input,sizeof(input),stdin);
        input[strcspn(input,"\n")]=0;

        strcpy(processed,input);
        toLowerCase(processed);

        if(strcmp(processed,"exit")==0)
            break;

        sem=extractSemester(processed);
        extractCourse(processed,course);
        extractDateKeyword(processed,dateWord);

        printf("Bot: ");
        respond(sem,course,dateWord);
        printf("\n");
    }

    return 0;
}


7. Context Handling for Follow-ups

#include <stdio.h>
#include <string.h>
#include <ctype.h>

char lastTopic[50] = "";
char lastYear[50] = "";

void toLowerCase(char *str)
{
    for(int i=0; str[i]; i++)
        str[i] = tolower(str[i]);
}

void extractYear(char *str, char year[])
{
    if(strstr(str,"first")) strcpy(year,"1st year");
    else if(strstr(str,"second")) strcpy(year,"2nd year");
    else if(strstr(str,"third")) strcpy(year,"3rd year");
    else if(strstr(str,"fourth")) strcpy(year,"4th year");
}

void respond()
{
    if(strcmp(lastTopic,"exam")==0 && strlen(lastYear)>0)
        printf("The exam schedule for %s students will be announced next month.\n",lastYear);

    else if(strcmp(lastTopic,"exam")==0)
        printf("Which year students are you asking about?\n");

    else if(strcmp(lastTopic,"fees")==0)
        printf("Fee structure details are available on the institute portal.\n");

    else
        printf("I could not understand the query.\n");
}

int main()
{
    char input[200];
    char processed[200];
    char year[50]="";

    printf("Institute Chatbot with Context Handling\n");
    printf("Type 'exit' to quit\n\n");

    while(1)
    {
        printf("You: ");
        fgets(input,sizeof(input),stdin);
        input[strcspn(input,"\n")] = 0;

        strcpy(processed,input);
        toLowerCase(processed);

        if(strcmp(processed,"exit")==0)
            break;

        if(strstr(processed,"exam"))
            strcpy(lastTopic,"exam");

        if(strstr(processed,"fees"))
            strcpy(lastTopic,"fees");

        extractYear(processed,year);

        if(strlen(year)>0)
            strcpy(lastYear,year);

        printf("Bot: ");
        respond();
        printf("\n");
    }

    return 0;
}

8. Fallbacks And Handover

#include <stdio.h>
#include <string.h>
#include <ctype.h>

int fallbackCount = 0;

void toLowerCase(char *str)
{
    for(int i=0; str[i]; i++)
        str[i] = tolower(str[i]);
}

int detectIntent(char *str)
{
    if(strstr(str,"fees")) return 1;
    if(strstr(str,"admission")) return 2;
    if(strstr(str,"exam")) return 3;
    if(strstr(str,"hostel")) return 4;
    if(strstr(str,"placement")) return 5;
    return 0;
}

void respond(int intent)
{
    if(intent==1)
        printf("The fee structure ranges from 80000 to 120000 per year depending on the course.\n");

    else if(intent==2)
        printf("Admissions open in June. Applications are available on the institute website.\n");

    else if(intent==3)
        printf("Semester exams are conducted twice a year according to the university timetable.\n");

    else if(intent==4)
        printf("Hostel facilities are available for both boys and girls with separate accommodation.\n");

    else if(intent==5)
        printf("The placement cell works with companies like TCS, Infosys and Wipro.\n");
}

void fallback()
{
    fallbackCount++;

    if(fallbackCount==1)
    {
        printf("I am not sure I understood that. Could you please clarify your question?\n");
        printf("You can ask about admissions, fees, exams, hostel or placements.\n");
    }

    else if(fallbackCount==2)
    {
        printf("I am still unable to understand the query.\n");
        printf("Try asking something like: 'What are the fees?' or 'When are exams conducted?'\n");
    }

    else
    {
        printf("I recommend contacting a human advisor for further assistance.\n");
        printf("Email: advisor@institute.edu\n");
        printf("Help Desk: www.institute.edu/helpdesk\n");
        fallbackCount=0;
    }
}

int main()
{
    char input[200];
    char processed[200];
    int intent;

    printf("Institute Support Chatbot\n");
    printf("Type 'exit' to quit\n\n");

    while(1)
    {
        printf("You: ");
        fgets(input,sizeof(input),stdin);
        input[strcspn(input,"\n")] = 0;

        strcpy(processed,input);
        toLowerCase(processed);

        if(strcmp(processed,"exit")==0)
            break;

        intent = detectIntent(processed);

        printf("Bot: ");

        if(intent!=0)
        {
            respond(intent);
            fallbackCount=0;
        }
        else
        {
            fallback();
        }

        printf("\n");
    }

    return 0;
}


